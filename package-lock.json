{
  "name": "tvashtr-suite",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "tvashtr-suite",
      "hasInstallScript": true,
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@tvashtr/checkout": {
      "resolved": "packages/tvashtr-checkout",
      "link": true
    },
    "node_modules/@tvashtr/core": {
      "resolved": "packages/tvashtr-core",
      "link": true
    },
    "node_modules/@tvashtr/google-sheets": {
      "resolved": "packages/tvashtr-google-sheets",
      "link": true
    },
    "node_modules/@tvashtr/notifications": {
      "resolved": "packages/tvashtr-notifications",
      "link": true
    },
    "node_modules/@tvashtr/ui": {
      "resolved": "packages/tvashtr-ui",
      "link": true
    },
    "node_modules/tvashtr-cli": {
      "resolved": "packages/tvashtr-cli",
      "link": true
    },
    "packages/tvashtr-checkout": {
      "name": "@tvashtr/checkout",
      "version": "1.0.0",
      "dependencies": {
        "@tvashtr/core": "*",
        "@tvashtr/notifications": "*"
      }
    },
    "packages/tvashtr-cli": {
      "version": "1.0.0",
      "bin": {
        "tvashtr": "bin/tvashtr.js"
      }
    },
    "packages/tvashtr-core": {
      "name": "@tvashtr/core",
      "version": "1.0.0"
    },
    "packages/tvashtr-google-sheets": {
      "name": "@tvashtr/google-sheets",
      "version": "1.0.0",
      "dependencies": {
        "@tvashtr/core": "*"
      }
    },
    "packages/tvashtr-notifications": {
      "name": "@tvashtr/notifications",
      "version": "1.0.0",
      "dependencies": {
        "@tvashtr/core": "*"
      }
    },
    "packages/tvashtr-ui": {
      "name": "@tvashtr/ui",
      "version": "1.0.0",
      "dependencies": {
        "@tvashtr/checkout": "*",
        "@tvashtr/core": "*",
        "@tvashtr/google-sheets": "*"
      }
    }
  }
}
