# Theme Configuration
NUXT_PUBLIC_THEME=default
NUXT_THEME_CSS=~/assets/themes/default/main.css

# Feature Flags
NUXT_PUBLIC_ENABLE_CHECKOUT=true
NUXT_PUBLIC_ENABLE_SERVICE_MODE=false
NUXT_PUBLIC_ENABLE_RECIPES=false
NUXT_PUBLIC_ENABLE_BLOG=false

# Google Sheets CMS
NUXT_PUBLIC_SHEET_ID=
